<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 Not found | Failik</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/elements/header.css">
    <link rel="stylesheet" href="/elements/sidebar.css">
    <link rel="stylesheet" href="/forms/standardForm.css"> 
  </head>
  <body>
    <div class="page-container">
      <%- include("../partials/sideBar", {folders: locals.folders || []}); %>
      
      <div class="content">
        <%- include("../partials/header") %>

        <main class="main-content" style="align-items: center;">
          <div class="form-card">
            
            <div class="error-card">
              <div class="error-card__info">
                <div class="error-card__icon">
                  <i class="fa-solid fa-circle-question"></i>
                </div>
                
                <h2 class="form-card__title">Ooops! 404 Error</h2>
                <p class="error-card__message">Nout found. This page does not exist.</p>
              </div>
              
              <div class="error-card__actions">
                <a href="/home" class="btn btn--primary">
                  <i class="fa-solid fa-house"></i> Back to home
                </a>
                <a href="#" onclick="history.back(); return false;" class="btn-back-link">
                  <i class="fa-solid fa-arrow-left"></i> Go Back
                </a>
              </div>
            </div>

          </div>
        </main>
      </div>
    </div>
  </body>
</html>