<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create new folder | Failik</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/elements/header.css">
    <link rel="stylesheet" href="/elements/sidebar.css">
    <link rel="stylesheet" href="/forms/standardForm.css">
  </head>
  <body>
    <div class="page-layout">
      <%- include("../partials/sideBar", {folders: locals.folders || []}); %>
      
      <div class="content">
        <%- include("../partials/header") %>

        <main class="main-content">
          <div class="form-card">
            
            <header class="form-card__header">
              <h2 class="form-card__title">Create new folder</h2>
              <p class="form-card__subtitle">Give your new folder a clear name to organize your files</p>
            </header>

            <form action="/folder/create" method="POST" class="form">
              
              <div class="form-field <%= (locals.errors?.title) ? 'form-field--error' : '' %>">
                <label for="title" class="form-field__label">Folder Title</label>
                <input 
                  type="text" 
                  name="title" 
                  id="title" 
                  class="form-field__input"
                  autocomplete="off"
                  placeholder="e.g., University Projects"
                  value="<%= locals?.data?.title || '' %>" 
                  required 
                />
                
                <% if (locals.errors?.title) { %>
                  <span class="form-field__error-text">
                    <i class="fa-solid fa-circle-exclamation"></i> <%= errors.title.msg %>
                  </span>
                <% } %>
              </div>

              <div class="form__actions">
                <button type="submit" class="btn btn--primary">
                  <i class="fa-solid fa-folder-plus"></i> Create Folder
                </button>
              </div>

            </form>
          </div>
        </main>
      </div>
    </div>
  </body>
</html>