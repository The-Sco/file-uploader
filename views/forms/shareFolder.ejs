<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Share <%= folder.title %> | Failik</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/elements/header.css">
    <link rel="stylesheet" href="/elements/sidebar.css">
    <link rel="stylesheet" href="/forms/standardForm.css">
  </head>
  <body>
    <div class="page-container">
      <%- include("../partials/sideBar", {folders: locals.folders || []}); %>
      
      <div class="content">
        <%- include("../partials/header") %>

        
        <main class="main-content">
          
          <div class="form-card">
            
            <header class="form-card__header">
              <h2 class="form-card__title">Share "<%= folder.title %>"</h2>
              <p class="form-card__subtitle">Generate link to share this folder</p>
            </header>

            <form action="/folder/share/generate/<%= folder.id %>" method="POST" class="form">
              
              <div class="form-field <%= (locals.errors?.duration) ? 'form-field--error' : '' %>">
                <label for="duration" class="form-field__label">Link duration (1 - 90 days)</label>
                <input 
                  type="number" 
                  name="duration" 
                  id="duration" 
                  class="form-field__input input--number"
                  autocomplete="off"
                  value="<%= locals?.data?.duration || '' %>" 
                  required 
                />
                
                <% if (locals.errors?.duration) { %>
                  <span class="form-field__error-text">
                    <i class="fa-solid fa-circle-exclamation"></i> <%= errors.duration.msg %>
                  </span>
                <% } %>
              </div>

              <div class="form__actions">
                <button type="submit" class="btn btn--primary">
                  <i class="fa-solid fa-link"></i> Generate
                </button>
              </div>

            </form>
          </div>
        </main>
      </div>
    </div>
  </body>
</html>