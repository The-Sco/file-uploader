<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Upload file | Failik</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/elements/header.css">
    <link rel="stylesheet" href="/elements/sidebar.css">
    <link rel="stylesheet" href="/forms/uploadFile.css">
  </head>
  
  <body>
    <div class="page-layout">
      <%- include("../partials/sideBar", {folders: locals.folders || []}); %>
      
      <div class="content">
        <%- include("../partials/header") %>

        <main class="main-content">
          <div class="form-card">
            
            <header class="form-card__header">
              <h2 class="form-card__title">Upload a file</h2>
              <p class="form-card__subtitle">Select a file and choose a target destination folder</p>
            </header>

            <form action="/file/upload" method="POST" class="form" enctype="multipart/form-data">
              
              <div class="form-field <%= (locals.errors?.file) ? 'form-field--error' : '' %>">
                <label class="form-field__label">File</label>
                
                <label for="file" class="file-dropzone">
                  <input type="file" name="file" id="file" class="file-dropzone__input" required <%= (locals.errors?.folder) ? 'disabled' : '' %>/>
                  <i class="fa-solid fa-cloud-arrow-up file-dropzone__icon"></i>
                  <span class="file-dropzone__text" id="dropzone-text">Click to browse or drag file here</span> 
                  <span class="file-dropzone__subtext">Any files up to 50MB</span>
                </label>

                <% if (locals.errors?.file) { %>
                  <span class="form-field__error-text">
                    <i class="fa-solid fa-circle-exclamation"></i> <%= errors.file.msg %>
                  </span>
                <% } %>
              </div>

              <div class="form-field <%= (locals.errors?.folder) ? 'form-field--error' : '' %>">
                <label for="folder" class="form-field__label">Target Folder</label>

                <div class="select-wrapper">
                  <select id="folder" name="folder" class="form-field__select" <%= (folders.length === 0) ? 'disabled="true"' : '' %>>
                    <% folders.forEach(f => { %>
                      <option 
                        value="<%= f.id %>"
                        <%= (f.id == locals.selectedFolder) ? 'selected' : '' %>
                      ><%= f.title %></option>
                    <% }) %>
                  </select>
                </div>

                <% if (locals.errors?.folder) { %>
                  <span class="form-field__error-text">
                    <i class="fa-solid fa-circle-exclamation"></i> <%= errors.folder.msg %>
                  </span>
                <% } %>
              </div>

              <div class="form__actions">
                <button type="submit" class="btn btn--primary" <%= (locals.errors?.folder) ? 'disabled' : '' %>>
                  <i class="fa-solid fa-plus"></i> Upload File
                </button>
              </div>

            </form>
          </div>
        </main>
      </div>
    </div>
  </body>

  <script>
  const fileField = document.querySelector(".form-field:has(#file)");
  const fileInput = document.getElementById('file');
  const dropzone = document.querySelector('.file-dropzone');
  const dropzoneText = document.getElementById('dropzone-text');

  fileInput.addEventListener('change', (e) => {
    if (fileInput.files.length > 0) {
      const file = fileInput.files[0];
      const fileSizeMb = (file.size / 1000000).toFixed(2);
      dropzoneText.innerText = `Selected: ${file.name} (${fileSizeMb} MB)`;
      fileField.classList.remove("form-field--error");
    }

  });

  ['dragenter', 'dragover'].forEach(eventName => {
    dropzone.addEventListener(eventName, (e) => {
      e.preventDefault();
      dropzone.classList.add('file-dropzone--active');
    }, false);
  });

  ['dragleave', 'drop'].forEach(eventName => {
    dropzone.addEventListener(eventName, (e) => {
      e.preventDefault();
      fileField.classList.remove("form-field--error");
      dropzone.classList.remove('file-dropzone--active');
    }, false);
  });

  dropzone.addEventListener('drop', (e) => {
    const dt = e.dataTransfer;
    const files = dt.files;

    if (files.length > 0) {
      fileInput.files = files;
      
      const file = files[0];
      const fileSizeMb = (file.size / 1000000).toFixed(2);
      dropzoneText.innerText = `Selected: ${file.name} (${fileSizeMb} MB)`;
    }
  });
</script>
</html>