<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Upload file</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  </head>
  
  <body>
    
    <%- include("../partials/header") %>

    <main class="page-container">
      <div class="form-card">
        
        <header class="card__header">
          <h2 class="form-card__title">Upload a file</h2>
        </header>

        <form action="/file/upload" method="POST" class="form" enctype="multipart/form-data">
          
          <div class="form-field <%= (locals.errors?.file) ? 'form-field--error' : '' %>">
            <label for="file" class="form-field__label">File</label>
            <input type="file" name="file" id="file" required />
            <% if (locals.errors?.file) { %>
              <span class="form-field__error-text"><%= errors.file.msg %></span>
            <% } %>
          </div>

          <div class="form-field <%= (locals.errors?.folder) ? 'form-field--error' : '' %>">
            <label for="folder" class="form-field__label">Folder</label>

            <select id="folder" name="folder" class="form-field__select">
            <% folders.forEach(f => { %>
              <option 
                value="<%= f.id %>"
                <%= (f.id == locals.selectedFolder) ? 'selected' : '' %>
              ><%= f.title %></option>
            <% }) %>
            </select>

            <% if (locals.errors?.folder) { %>
              <span class="form-field__error-text"><%= errors.folder.msg %></span>
            <% } %>
          </div>

          <div class="form__actions">
            <button <%= (locals.errors?.folder) ? 'disabled="true' : '' %>type="submit" class="btn btn--primary">Create</button>
          </div>

        </form>
      </div>
    </main>

  </body>
</html>