<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Share link | Failik</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/elements/header.css">
    <link rel="stylesheet" href="/elements/sidebar.css">
    <link rel="stylesheet" href="/forms/standardForm.css"> 
  </head>
  <body>
    <div class="page-layout">
      <%- include("../partials/sideBar", {folders: locals.folders || []}); %>
      
      <div class="content">
        <%- include("../partials/header") %>

        <main class="main-content">
          <div class="form-card">
            
            <header class="form-card__header">
              <h2 class="form-card__title">Your link is ready</h2>
              <p class="form-card__subtitle">
                Don't share this with people you don't trust
              </p>
            </header>

            <div class="form-field form-field--share-link">
              <input 
                type="text" 
                name="shareLink" 
                class="form-field__input input--share-link"
                value="<%= locals?.shareLink || '' %>" 
                readonly
              />
              <button class="btn btn--primary btn--xs share-link__copy-button" type="button">Copy</button>
            </div>

            <div class="error-card__actions" style="margin-top: 1rem;">
              <a href="/home" class="btn btn--primary">
                <i class="fa-solid fa-house"></i> Back to home
              </a>
            </div>

          </div>
        </main>
      </div>
    </div>
    <script>
      const copyButton = document.querySelector(".share-link__copy-button");
      const shareLinkField = document.querySelector(".input--share-link")

      copyButton.addEventListener("click", () => {
        copyButton.textContent = "Copied!";
        navigator.clipboard.writeText(shareLinkField.value)
        .then(() => {
          console.log(shareLinkField.value);
          setTimeout(() => {
            copyButton.textContent = "Copy";
          }, 1500);
        })
      })
    </script>
  </body>
</html>