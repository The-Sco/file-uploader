<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Home</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />  </head>
  <body>
    <%- include("../partials/header") %>
    <%- include("../partials/sideBar", {folders: locals.folders || []}); %>

    <main class="main">
      <div class="main__header">
        <div class="main__header--left">
          <h2 class="main__header__title">
            Your files
          </h2>
          <span class="main__header__counter">
            <%= files.length %> files
          </span>
        </div>
      </div>
      <div class="files-grid">
        <% files.forEach(file => { %>
          <%- include("../partials/file-grid-element", {file}) %>
        <% }) %>
      </div>
    </main>
  </body>
</html>
