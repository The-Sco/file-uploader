<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= query %> | Failik</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />  
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/elements/sidebar.css">
    <link rel="stylesheet" href="/elements/header.css">
    <link rel="stylesheet" href="/elements/file-grid-element.css">
    <link rel="stylesheet" href="/pages/home.css">
  </head>
  <style>
    .main-content__header {
      margin-top: 1rem;
    }
  </style>
  <body>
    <div class="page-layout">
      <%- include("../partials/sideBar", {folders: locals.folders || []}); %>
      
      <div class="content">
        <%- include("../partials/header") %>
        <main class="main-content">

          <div class="main-content__navigation">
            <a href="#" onclick="history.back(); return false;" class="btn-back">
              <i class="fa-solid fa-arrow-left"></i> Back
            </a>
          </div>

          <header class="main-content__header">
            <div class="main-content__header-left">
              <h2 class="main-content__title">Files matching the query "<%= query %>"</h2>
              <span class="main-content__counter">
                <%= files.length %> <%= files.length === 1 ? 'file' : 'files' %>
              </span>
            </div>
          </header>
  
          <% if (files.length > 0) { %>
            <div class="files-grid">
              <% files.forEach(file => { %>
                <%- include("../partials/file-grid-element", {file}) %>
              <% }) %>
            </div>
          <% } else { %>
            <div class="empty-state">
              <i class="fa-solid fa-file-circle-question empty-state__icon"></i>
              <p class="empty-state__text">No files found</p>
              <a href="/file/upload" class="btn btn--primary">Upload file</a>
            </div>
          <% } %>
  
        </main>
      </div>
      
    </div>
  </body>
</html>