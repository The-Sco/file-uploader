<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= folder.title %> | Failik</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />  
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/elements/sidebar.css">
    <link rel="stylesheet" href="/elements/header.css">
    <link rel="stylesheet" href="/elements/file-grid-element.css">
    <link rel="stylesheet" href="/pages/singleFolder.css">
  </head>
  <body>
    <div class="page-container">
      <%- include("../partials/sideBar", {folders: locals.folders || []}); %>
      
      <div class="content">
        <%- include("../partials/header") %>

        <main class="main-content">
          <header class="main-content__header">
            <div class="main-content__header-left">
              <h2 class="main-content__title">
                <i class="fa-solid fa-folder-open main-content__folder-icon"></i>
                <%= folder.title %>
              </h2>
              <span class="main-content__counter">
                <%= folder.files.length %> <%= folder.files.length === 1 ? 'file' : 'files' %>
              </span>
            </div>
            
          </header>

          <% if (folder.files.length > 0) { %>
            <div class="files-grid">
              <% folder.files.forEach(file => { %>
                <%- include("../partials/file-grid-element", { file, folder, isShared: true, key }) %>
              <% }) %>
            </div>
          <% } else { %>
            <div class="empty-state">
              <i class="fa-solid fa-folder-open empty-state__icon"></i>
              <p class="empty-state__text">This folder is completely empty</p>
            </div>
          <% } %>
        </main>
      </div>
    </div>
  </body>
</html>