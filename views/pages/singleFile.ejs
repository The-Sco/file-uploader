<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= file.name %> | Failik</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/elements/header.css">
    <link rel="stylesheet" href="/elements/sidebar.css">
    <link rel="stylesheet" href="/elements/menu-folder.css">
    <link rel="stylesheet" href="/pages/singleFile.css">
  </head>
  <body>
    <div class="page-container">
      <%- include("../partials/sideBar", {folders: locals.folders || []}); %>
      
      <div class="content">
        <%- include("../partials/header") %>

        <main class="main-content">
          
          <div class="main-content__navigation">
            <a href="#" onclick="history.back(); return false;" class="btn-back">
              <i class="fa-solid fa-arrow-left"></i> Back
            </a>
          </div>

          <div class="file-viewer">
            
            <div class="file-viewer__preview">
              <% if (isImage) { %>
                <div class="file-viewer__image-wrapper">
                  <img src="<%= file.link %>" alt="<%= file.name %>" class="file-viewer__img">
                </div>
              <% } else if (isReadable) { %>
                <div class="file-viewer__text-wrapper">
                  <pre class="file-viewer__code"><code><%= fileTextContent %></code></pre>
                </div>
              <% } else { %>            
                <div class="file-viewer__icon-wrapper">
                  <i class="fa-solid fa-file-shield file-viewer__icon" aria-hidden="true"></i>
                  <span class="file-viewer__extension"><%= file.trueExtension.toUpperCase() %></span>
                </div>
              <% } %>
            </div>

            <div class="file-viewer__details">
              <div class="file-viewer__meta">
                <h2 class="file-viewer__title" title="<%= file.name %>"><%= file.name %></h2>
                <span class="file-viewer__size"><%= formatedSize %> MB</span>
              </div>

              <div class="file-viewer__actions">
                <a href="<%= file.link.replace('/upload/', '/upload/fl_attachment/') %>" 
                   download="<%= file.name %>" 
                   class="btn btn--primary">
                   <i class="fa-solid fa-download"></i> Download File
                </a>
                <form action="/file/delete" method="post" class="file-viewer__delete-form">
                  <input type="hidden" name="fileId" value="<%= file.id %>">
                  <button type="submit" class="btn btn--danger" onclick="return confirm('Delete this file?')">
                    <i class="fa-solid fa-trash-can"></i> Delete file
                  </button>
                </form>
              </div>
            </div>

          </div>

        </main>
      </div>
    </div>
  </body>
</html>