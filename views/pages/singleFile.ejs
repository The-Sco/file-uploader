<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= file.name %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  </head>
  <body>
    
    <%- include("../partials/header") %>
    <%- include("../partials/sideBar", {folders: locals.folders || []}); %>

    <main class="main">
      <a href="#" onclick="history.back(); return false;" class="back-navigation">
        ← Back
      </a>
      <div class="single-file-preview">
        <% if (isImage) { %>
          <img src="<%= file.link%>" alt="" class="single-file__image">
        <% } else if (isReadable) { %>
          <p class="single-file__preview-text"><%= fileTextContent %></p>
        <% } else { %>            
          <i class="fa-solid fa-file" aria-hidden="true"></i>
        <% } %>
      </div>

      <div class="single-file__info">
        <div class="single-file__header">
          <h2 class="single-file__title"><%= file.name %></h2>
          <p class="single-file__size"><%= formatedSize %> Mb</p>
        </div>
      </div>

      <div class="single-file__actions">
        <a href="<%= file.link.replace('/upload/', '/upload/fl_attachment/') %>" 
           download="<%= file.name %>" 
           class="btn btn--primary">
           Download File
        </a>
        <form action="/file/delete" method="post">
          <input type="hidden" name="fileId" value="<%= file.id %>">
          <button type="submit" class="btn btn--danger" onclick="return confirm('Delete this file?')">Delete file</button>
        </form>
      </div>
      
    </main>
  </body>
</html>
