<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= folder.title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />  </head>
  <body>
    <%- include("../partials/header") %>
    <%- include("../partials/sideBar", {folders: locals.folders || []}); %>

    <main class="main">
      <div class="main__header">
        <div class="main__header--left">
          <h2 class="main__header__title">
            <%= folder.title %>
          </h2>
          <span class="main__header__counter">
            <%= folder.files.length %> files
          </span>
        </div>
        <div class="main__header__actions">
          <a class="btn btn--secondary" href="/file/upload?folder=<%= folder.id %>">
            Upload to <%= folder.title %>
          </a>
          <form action="/folder/delete" method="post">
            <input type="hidden" name="folderId" value="<%= folder.id %>">
            <button type="submit" class="btn btn--danger" onclick="return confirm('Delete this folder? Its files will be deleted too')">Delete folder</button>
          </form>
        </div>
      </div>
      <div class="files-grid">
        <% folder.files.forEach(file => { %>
          <%- include("../partials/file-grid-element", {file}) %>
        <% }) %>
      </div>
    </main>
  </body>
</html>
