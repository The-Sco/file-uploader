<% 
  const imgExtensions = ["jpg", "jpeg", "png", "webp", "avif"];
  const isImage = imgExtensions.includes(file.trueExtension.toLowerCase());
  const formatedSize = (file.size / 1_000_000).toFixed(2);
  let link = `/file/single/${file.id}`;
  if (locals.isShared) {
    link = `/file/shared/${file.id}?key=${key}`;
  }
%>

<div class="file-card">
  <a href="<%= link %>" class="file-card__link">

    <div class="file-card__preview">
      <% if (isImage) { %>
        <img src="<%= file.link %>" class="file-card__img" alt="<%= file.name %>" loading="lazy">
      <% } else { %>
        <div class="file-card__icon-wrapper">
          <i class="fa-solid fa-file-lines file-card__icon" aria-hidden="true"></i>
          <span class="file-card__extension-badge"><%= file.trueExtension.toUpperCase() %></span>
        </div>
      <% } %>
    </div>

    <div class="file-card__info">
      <span class="file-card__name" title="<%= file.name %>">
        <%= file.name %>
      </span>
      <span class="file-card__size">
        <%= formatedSize %> MB
      </span>
    </div>

  </a>
</div>